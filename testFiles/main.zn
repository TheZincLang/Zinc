import { square, cube } from "./math.zn"
import * as math from "./math.zn"
import types { PI } from "./math.zn"

// ── Zinc parser test file ───────────────────────────────────────────────
// Exercises every construct the parser currently understands.
// NOTE: imports must lead the file — findImports() (the discovery pre-pass)
// scans only a leading run of import statements and stops at the first comment.

/* ── enums (global scope only) ────────────────────────────────────────── */
const enum Color {
    Red,
    Green = 5,
    Blue
}

enum Direction: int {
    North = 1,
    East,
    South,
    West,
}

/* ── interfaces (field + method signatures, no bodies) ────────────────── */
interface Drawable {
    fn draw(): void
}

interface Sized {
    width: int
    height: int
    fn area(): int
}

/* ── groups (bulk clause targets) ─────────────────────────────────────── */
group Renderable {
    Drawable,
    Sized,
}

/* ── structs (fields + methods, no constructors/inheritance) ──────────── */
struct Point {
    x: int,
    y: int,

    fn manhattan(): int {
        return x + y
    }
}

/* ── classes (inheritance clauses, members, constructors, modifiers) ──── */
class Shape {
    public name: string
    private sides: int

    init(name: string, sides: int) {
        self.name = name
        self.sides = sides
    }

    public fn describe(): string {
        return name
    }
}

class Rect extends Shape mixin Movable, Resizable implements Renderable owns Point serves Canvas {
    topLeft: Point
    size: Point
    static label: string[]

    init(topLeft: Point, size: Point) {
        self.topLeft = topLeft
        self.size = size
    }

    override public fn describe(): string {
        return "rect"
    }
}

/* ── variable declarations ────────────────────────────────────────────── */
let counter: int = 0
let origin: Point
const greeting: string = "hello"
let ratio = 3.14
let smallFloat = 1.5f
let letter = 'z'
let isReady = True
let numbers: int[]

/* ── union types (parse only; narrowing is the type checker's job) ────── */
let mixedVal: int | string = 42
let nullable: string | null = greeting
let unionArr: int[] | string[] | bool

/* ── operator precedence & expressions ────────────────────────────────── */
let arithmetic = 2 + 3 * 4 - 10 / 2
let power = 2 ** 3 ** 2
let bitwise = 1 | 2 & 3 ^ 4
let shifted = 8 >> 1 << 2
let comparison = (counter < 10) && (counter >= 0) || isReady
let ternary = counter > 0 ? Color.Green : Color.Red
let negated = -counter
let inverted = ~bitwise
let notReady = !isReady

/* ── assignments (all compound forms) ─────────────────────────────────── */
counter = 10
counter += 5
counter -= 2
counter *= 3
counter /= 2
counter %= 4
counter **= 2
counter |= 1
counter &= 6
counter ^= 3
counter <<= 1
counter >>= 1

/* ── postfix & prefix ─────────────────────────────────────────────────── */
counter++
print(counter)
let prefixed = ++counter
counter--

/* ── field access, indexing and calls ─────────────────────────────────── */
print(greeting)
print("counter is", counter)
numbers[0] = 42
let first = numbers[counter + 1]
let nested = container.items[0].value
object.method(1, 2, 3)

/* ── string templates with interpolation ──────────────────────────────── */
let message = `counter is ${counter} and double is ${counter * 2}!`
let plain = `no interpolation here`

/* ── if / else if / else ──────────────────────────────────────────────── */
if (counter > 100) {
    print("big")
} else if (counter > 10) {
    print("medium")
} else {
    print("small")
}

/* ── while loop with break / continue ─────────────────────────────────── */
while (counter > 0) {
    counter -= 1
    if (counter == 3) {
        continue
    }
    if (counter == 1) {
        break
    }
    print(counter)
}

/* ── switch with cases, default and break ─────────────────────────────── */
switch (counter) {
    case 0: {
        print("value is 0")
        break
    }
    case 1: {
        let local = counter * 10
        print(local)
        break
    }
    default: {
        print("value is something else")
        break
    }
}

/* ── function declarations ────────────────────────────────────────────── */
fn noArgs() {
    print("hello")
}

func add(a: int, b: int): int {
    return a + b
}

function greet(name: string): string {
    let line = `hi ${name}`
    return line
}

fn sumAll(values: int[]): int {
    let total = 0
    let i = 0
    while (i < 10) {
        total += values[i]
        i += 1
    }
    return total
}

fn makeList(): int[] {
    return numbers
}

export async fn fetchValue(id: int): int {
    return add(id, 1)
}

fn parseValue(input: string): int | string | null {
    return input
}

/* ── generics (type parameters at binding sites) ──────────────────────── */
struct Box<T> {
    value: T
}

class Container<T> extends Box implements Sized {
    items: T[]

    fn first(): T {
        return items[0]
    }
}

class Map<K, V> {
    keys: K[]
    values: V[]
}

enum Maybe<T> {
    Some,
    None,
}

interface Comparable<T> {
    fn compareTo(other: T): int
}

fn identity<T>(value: T): T {
    return value
}

fn pick<T, F, C>(a: T, b: F, c: C): T {
    return a
}

/* ── generic type arguments in annotations ────────────────────────────── */
let boxed: Box<int>
let pair: Map<string, Box<int>>
let boxes: Box<int>[]
let eitherBox: Box<int | string>
let nestedBox: Box<Map<string, int>>

/* ── array literals (primary position) ────────────────────────────────── */
let empty = []
let primes = [2, 3, 5, 7, 11]
let trailing = [1, 2, 3,]
let nestedArr = [[1, 2], [3, 4]]
let mixed = [counter, counter + 1, add(1, 2)]
let indexedLiteral = [10, 20, 30][counter]

/* ── loop (infinite, exited via break) ────────────────────────────────── */
loop {
    counter -= 1
    if (counter == 0) {
        break
    }
}

/* ── for loops (C-style three-clause and for-in) ──────────────────────── */
for (let i = 0; i < 10; i++) {
    print(i)
}

for (let j = 10; j > 0; j -= 1) {
    if (j == 5) {
        continue
    }
    print(j)
}

for (item in numbers) {
    print(item)
}

for (;;) {
    break
}

/* ── lambdas / closures ───────────────────────────────────────────────── */
let noCapture = fn (x: int) => {
    return x + 1
}
let withReturnType = fn (x: int): int => {
    return x + 1
}
let withCapture = fn [counter, ref greeting](x: int): int => {
    return x + counter
}
let wildcard = fn [ref *](a: int, b: int) => {
    return a + b
}
let mixedCapture = fn [move counter, copy *]() => {
    return counter
}

/* ── keyword prefix operators ─────────────────────────────────────────── */
let instance = new Point(1, 2)
let kind = typeof counter
let fetched = await fetchValue(7)
let bytes = sizeof counter
delete instance

/* ── throw / try / catch / finally ────────────────────────────────────── */
fn risky(n: int): int {
    if (n < 0) {
        throw "negative input"
    }
    return n
}

try {
    let safe = risky(counter)
    print(safe)
} catch (err) {
    print(err)
} finally {
    print("done")
}

try {
    throw counter
} catch {
    print("caught without binding")
}

try {
    print("guarded")
} finally {
    print("cleanup only")
}

/* ── return statements ────────────────────────────────────────────────── */
return counter + 1
